<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 센서 -->
    <!-- 이 앱은 기기의 조도 센서(주변 밝기 측정)를 반드시 필요로 합니다. -->
    <!-- android:required="true"로 설정되어 있기 때문에,
    조도 센서가 없는 기기(예: 일부 저가형 태블릿이나 구형 기기)에서는
    구글 플레이 스토어에서 이 앱을 검색하거나 다운로드할 수 없습니다. (하드웨어 필터링 적용) -->
    <uses-feature
        android:name="android.hardware.sensor.light"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lux"
        tools:targetApi="31">

        <!--
            일부 사용자에게는 더 넓은 화면이 표시되지 않을 수 있습니다

            폴더블폰(갤럭시 폴드 등)이나 태블릿, 혹은 최신 세로로 아주 긴 스마트폰 화면에서
            앱이 꽉 차게 나오지 않고, 위아래나 양옆에 검은 레터박스가 생길 수 있다.

            안드로이드 15부터는 전체 화면을 꽉 채워 쓰는 엣지 투 엣지(Edge-to-Edge) 레이아웃이 기본으로 강제 적용됨
        -->
        <meta-data android:name="android.max_aspect" android:value="2.4" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>